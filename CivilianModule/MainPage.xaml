<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CivilianModule.MainPage">

    <Grid RowDefinitions="*, 100">
        <Border StrokeShape="20" Padding="15" Grid.Row="0"
                VerticalOptions="Center" HorizontalOptions="Center">
            <VerticalStackLayout>
                <Label Text="Авторизация" Padding="10" FontSize="{OnIdiom 60, Phone=45}"/>

                <Entry Placeholder="Логин" FontSize="{OnIdiom 30, Phone=45}"/>
                <Entry Placeholder="Пароль" FontSize="{OnIdiom 30, Phone=45} "/>

                <Button Text="Вход" FontSize="{OnIdiom 25, Phone=45}"/>
            </VerticalStackLayout>
        </Border>

        <Button Text="Дополнительные настройки" Grid.Row="1" HeightRequest="30" WidthRequest="300" Clicked="OnOpenSpecialFeatures"/>
    </Grid>
</ContentPage>
